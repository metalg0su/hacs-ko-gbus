@startuml config_flow
title 경기버스정보 (kr_gbus) Config Flow

|Config Flow|
start

package "step_user — API 키 입력" {
  repeat
    :API 키 입력;
    :API 키로 각 클라이언트 검증\n(arrival, station);
    if (검증 성공?) then (yes)
    else (no)
      :에러 표시\n(auth / connection / unknown);
    endif
  repeat while (검증 실패?) is (재입력) not (성공)
}

:Config Entry 생성;

|Options Flow — 모니터 추가|

package "step_search_station — 정류장 검색" {
  repeat
    :정류장 이름 검색;
    :검색 결과 조회;
    if (결과 있음?) then (yes)
    else (no)
      :에러 표시;
    endif
  repeat while (결과 없음?) is (재검색) not (성공)
}

package "step_select_station — 정류장 선택" {
  :정류장 선택;
  :경유 노선 목록 조회;
}

package "step_select_route — 노선 선택" {
  :노선 선택;
}

:Device + Entity 추가\n(station_id, route_id, sta_order,\nstation_name, route_name);

stop

note right
  모니터 삭제는 HA UI에서
  디바이스 삭제로 처리
  (async_remove_config_entry_device)
end note

@enduml
